    "db:seed": "dotenv -e .env.local -- tsx src/db/seed.ts",
    "db:migrate-access-patch": "dotenv -e .env.local -- node scripts/run-sql-file.mjs scripts/migrate-booking-access-passes-patch.sql",
    "db:migrate-deal-offers": "dotenv -e .env.local -- node scripts/migrate-deal-offers.mjs"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
